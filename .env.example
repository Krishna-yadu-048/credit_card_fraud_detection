# ============================================================
#  Credit Card Fraud Detection — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git — it is in .gitignore.
# ============================================================

# ── MLflow ─────────────────────────────────────────────────
# Where your MLflow tracking server is running.
# For local development this is fine as-is.
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# If you use DagsHub as your MLflow remote, replace with:
# MLFLOW_TRACKING_URI=https://dagshub.com/<your-username>/<your-repo>.mlflow
# MLFLOW_TRACKING_USERNAME=<your-dagshub-username>
# MLFLOW_TRACKING_PASSWORD=<your-dagshub-token>

# ── DVC Remote Storage ─────────────────────────────────────
# Only needed if you configure a DVC remote (S3, GCS, DagsHub).
# Leave blank for local-only development.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1

# ── Docker Hub ─────────────────────────────────────────────
# Used by the CD pipeline (set as GitHub Actions secrets).
# DOCKER_USERNAME=your-dockerhub-username
# DOCKER_PASSWORD=your-dockerhub-access-token
